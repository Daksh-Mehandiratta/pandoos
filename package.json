{
  "name": "pandoos",
  "private": true,
  "version": "1.0.16",
  "description": "Pandoos Music Desktop App",
  "author": {
    "name": "Rajvansh",
    "email": "rajvansh2525@gmail.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-icon": "node scripts/generate-icon.mjs",
    "dist": "npm run generate-icon && npm run build && electron-builder",
    "dist:win": "npm run generate-icon && npm run build && electron-builder --win",
    "dist:mac": "npm run generate-icon && npm run build && electron-builder --mac",
    "dist:linux": "npm run generate-icon && npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.pandoos.music",
    "productName": "Pandoos Music",
    "copyright": "Copyright © 2025 Pandoos",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/logo.png",
      "node_modules/@distube/ytdl-core/**/*",
      "node_modules/m3u8stream/**/*",
      "node_modules/miniget/**/*",
      "node_modules/sax/**/*"
    ],
    "asarUnpack": [
      "dist-electron/preload.cjs",
      "node_modules/@distube/ytdl-core/**/*",
      "node_modules/m3u8stream/**/*",
      "node_modules/miniget/**/*",
      "node_modules/sax/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pandoos Music"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Audio"
    },
    "publish": {
      "provider": "github",
      "owner": "Rajvansh-1",
      "repo": "pandoos",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@types/canvas-confetti": "^1.9.0",
    "@upstash/redis": "^1.38.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "idb-keyval": "^6.2.4",
    "immer": "^11.1.8",
    "lucide-react": "^1.16.0",
    "node-vibrant": "^4.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.76.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "ytmusic-api": "^5.3.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vite-plugin-pwa": "^1.3.0"
  }
}



