# =====================================================
# Pandoos Music — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =====================================================

# ------- Supabase (Auth + Database) -------
# Get from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ------- Google OAuth -------
# For super-fast One Tap login
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# ------- YouTube Data API v3 (Search only — NOT playback) -------
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable "YouTube Data API v3" in your project.
# This key is SERVER-SIDE ONLY (Vercel Edge Functions). Never expose to browser.
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# ------- Upstash Redis (Cross-user search result cache) -------
# Get from: https://upstash.com → Create Database → REST API
# Prevents redundant YouTube API quota consumption across all users.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ------- Optional: Lyrics API -------
# Using LRCLIB (free, no key needed) as primary.
# Uncomment if you add a paid lyrics provider later.
# GENIUS_API_KEY=your-genius-token
